generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE
  LATE
}

enum AdMediaType {
  IMAGE
  VIDEO
}

model User {
  id          String       @id @default(cuid())
  name        String
  email       String       @unique
  password    String
  role        String       @default("VIEWER")
  permissions String[]     @default([])
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model StaffMember {
  id          String       @id @default(cuid())
  name        String
  designation String
  department  String?
  phone       String?
  sortOrder   Int          @default(0)
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  attendanceRecords AttendanceRecord[]

  @@index([sortOrder])
}

model Manager {
  id          String       @id @default(cuid())
  name        String
  designation String?
  phone       String?
  sortOrder   Int          @default(0)
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  attendanceRecords ManagerAttendanceRecord[]

  @@index([sortOrder])
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  staffId   String
  date      DateTime
  shift     String?
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  staff StaffMember @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([staffId])
}

model ManagerAttendanceRecord {
  id        String           @id @default(cuid())
  managerId String
  date      DateTime
  shift     String?
  status    AttendanceStatus @default(PRESENT)
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  manager Manager @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@index([date])
  @@index([managerId])
}

model EventRecord {
  id          String       @id @default(cuid())
  title       String
  clientName  String?
  companyName String?
  screenName  String?
  startAt     DateTime
  endAt       DateTime?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([startAt])
}

model MeetingSchedule {
  id        String       @id @default(cuid())
  title     String
  location  String?
  organizer String?
  startAt   DateTime
  endAt     DateTime?
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([startAt])
}

model Alert {
  id        String       @id @default(cuid())
  title     String
  message   String?
  alertType String       @default("INFO")
  priority  Int          @default(0)
  startAt   DateTime
  endAt     DateTime
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@index([startAt])
  @@index([endAt])
  @@index([priority])
}

model Advertisement {
  id             String       @id @default(cuid())
  title          String
  contactPerson  String?
  phone          String?
  mediaUrl       String?
  mediaType      AdMediaType?
  duration       Int?
  sortOrder      Int          @default(0)
  contractAmount Float?
  adLocation     String?
  remarks        String?
  status         RecordStatus @default(ACTIVE)
  startAt        DateTime?
  endAt          DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([status])
  @@index([title])
  @@index([contactPerson])
  @@index([phone])
  @@index([adLocation])
  @@index([startAt])
  @@index([endAt])
}

model WeatherSetting {
  id        String   @id @default(cuid())
  city      String
  provider  String   @default("weatherapi")
  apiKey    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MovieSchedule {
  id         String       @id @default(cuid())
  movieName  String
  screenName String
  showTime   DateTime
  status     RecordStatus @default(ACTIVE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([showTime])
}

model MovieScheduleSyncSetting {
  id              String    @id @default(cuid())
  enabled         Boolean   @default(false)
  sourceType      String    @default("digital_signage_api")
  apiUrl          String?
  apiToken        String?
  lastSyncAt      DateTime?
  lastSyncStatus  String?
  lastSyncMessage String?
  lastSyncCount   Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MovieScheduleSyncedRow {
  id                  String    @id @default(cuid())
  sourceKey           String    @unique
  movieName           String
  normalizedMovieName String?
  screenName          String
  showDate            String
  showTime            String
  showDateTime        DateTime?
  isActive            Boolean   @default(true)
  syncBatchId         String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([showDate])
  @@index([showDateTime])
  @@index([isActive])
  @@index([movieName])
  @@index([screenName])
  @@index([syncBatchId])
}

model MovieScheduleSyncLog {
  id         String    @id @default(cuid())
  status     String
  message    String?
  rowCount   Int       @default(0)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([status])
  @@index([startedAt])
}

model ItemSalesTarget {
  id              String       @id @default(cuid())
  itemName        String
  itemCode        String?
  itemCodes       String[]     @default([])
  dailyTarget     Int?
  weeklyTarget    Int?
  monthlyTarget   Int?
  startDate       DateTime?
  endDate         DateTime?
  displayOrder    Int          @default(0)
  calculationMode String?
  status          RecordStatus @default(ACTIVE)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([displayOrder])
  @@index([itemName])
  @@index([itemCode])
  @@index([status])
}

model ItemSalesImportSetting {
  id                String    @id @default(cuid())
  sharedFolderPath  String?
  autoImportEnabled Boolean   @default(false)
  lastScanAt        DateTime?
  lastImportAt      DateTime?
  lastImportStatus  String?
  lastImportMessage String?
  lastImportCount   Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ItemSalesImportBatch {
  id              String   @id @default(cuid())
  sourceFilename  String
  sourcePath      String
  reportDate      DateTime
  businessDateKey String
  fileHash        String   @unique
  status          String   @default("COMPLETED")
  rowCount        Int      @default(0)
  rawMetadata     Json?
  importedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  rows ItemSalesImportRow[]

  @@index([businessDateKey])
  @@index([reportDate])
  @@index([status])
  @@index([rowCount])
}

model ItemSalesImportRow {
  id              String   @id @default(cuid())
  importBatchId   String
  businessDateKey String
  itemCode        String?
  itemName        String
  categoryName    String?
  uom             String?
  quantitySold    Float    @default(0)
  amountPaid      Float?
  rawData         Json?
  createdAt       DateTime @default(now())

  importBatch ItemSalesImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([businessDateKey])
  @@index([itemCode])
  @@index([itemName])
  @@index([importBatchId])
}

model ConcessionPriceItem {
  id        String       @id @default(cuid())
  itemName  String
  category  String?
  price     Float
  sortOrder Int          @default(0)
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@index([status])
  @@index([category])
  @@index([sortOrder])
}

model DisplayPage {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  status      RecordStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
